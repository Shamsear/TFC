model push_subscriptions {
  id             String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId         String   @map("user_id")
  deviceType     String   @map("device_type")
  deviceName     String   @map("device_name")
  endpoint       String   @unique
  p256dhEnc      String   @map("p256dh_enc") // Encrypted AES ciphertext string
  authEnc        String   @map("auth_enc") // Encrypted AES ciphertext string
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  lastUsedAt     DateTime @default(now()) @map("last_used_at")
  consentGivenAt DateTime @default(now()) @map("consent_given_at")
  user           users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model notifications_inbox {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId     String   @map("user_id")
  title      String
  body       String
  category   String   @default("general")
  url        String?
  entityId   String?  @map("entity_id")
  entityType String?  @map("entity_type")
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")
  user       users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model push_delivery_log {
  id             String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  subscriptionId String   @map("subscription_id")
  sentAt         DateTime @default(now()) @map("sent_at")
  status         String // "SUCCESS", "FAILED", "410_EXPIRED", "429_RATE_LIMIT", "CLICKED"
  errorMessage   String?  @map("error_message")
  category       String
}

model sub_admin_seasons {
  userId    String   @map("user_id")
  seasonId  String   @map("season_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   users   @relation(fields: [userId], references: [id], onDelete: Cascade)
  season seasons @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@id([userId, seasonId])
  @@index([userId])
  @@index([seasonId])
}

model team_badges {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  teamId      String   @map("team_id")
  badgeKey    String   @map("badge_key") // e.g. "IRON_CURTAIN", "GALE_FORCE"
  badgeName   String   @map("badge_name")
  tier        String   // "BRONZE", "SILVER", "GOLD", "PLATINUM"
  seasonId    String?  @map("season_id") // Optional: links to season if earned seasonally
  unlockedAt  DateTime @default(now()) @map("unlocked_at")

  // Relations
  team        teams    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  season      seasons? @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([teamId, badgeKey, seasonId]) // Prevent duplicate badge awards for the same season
}

model team_xp_history {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  teamId      String   @map("team_id")
  amount      Int      // e.g. 20, 100, 50
  xpType      String   @map("xp_type") // e.g. "MATCH_PLAYED", "MATCH_WON", "GOAL_SCORED", "BADGE_UNLOCKED"
  description String   // Detailed description, e.g. "Played match vs Arsenal (1-1)", "Unlocked 'Iron Curtain' badge"
  matchId     String?  @map("match_id") // Optional link to match
  badgeKey    String?  @map("badge_key") // Optional link to badge key
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  team        teams    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([createdAt])
}

model managers {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name      String   @unique
  photoUrl  String?  @map("photo_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  teamLinks manager_teams[]
}

model manager_teams {
  managerId String   @map("manager_id")
  teamId    String   @map("team_id")
  isCurrent Boolean  @default(true) @map("is_current")
  createdAt DateTime @default(now()) @map("created_at")

  manager   managers @relation(fields: [managerId], references: [id], onDelete: Cascade)
  team      teams    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([managerId, teamId])
  @@index([managerId])
  @@index([teamId])
}
