{
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/sql-wasm.wasm",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/wasm"
        }
      ]
    }
  ],
  "functions": {
    "app/api/import/preview/route.ts": {
      "maxDuration": 60
    },
    "app/api/import/stream/route.ts": {
      "maxDuration": 300
    }
  }
}
